# ── Vercel environment variables ──────────────────────────────────────────────
# Copy this file to .env.local for local development.
# In Vercel: Settings → Environment Variables

# Render API service URL (no trailing slash)
# Development: http://localhost:5139
# Production:  https://quickserveqr-api.onrender.com
NEXT_PUBLIC_API_URL=http://localhost:5139

# Public URL of this Next.js app — used to generate scannable QR code URLs
# Development: http://localhost:3000
# Production:  https://your-app.vercel.app
NEXT_PUBLIC_SITE_URL=http://localhost:3000
