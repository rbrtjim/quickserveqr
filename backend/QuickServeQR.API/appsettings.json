{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "ConnectionStrings": {
    "DefaultConnection": "Host=SUPABASE_HOST;Port=5432;Database=postgres;Username=postgres;Password=SUPABASE_PASSWORD;SSL Mode=Require;Trust Server Certificate=true"
  },
